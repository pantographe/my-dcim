<%= form_with(model: move_connection,
              url: move_connections_path(move),
              html: { class: "move_connection_form p-4 rounded border bg-body-tertiary", role: "form" }) do |f| %>
  <%= render FormErrorsComponent.new(move_connection) %>
  <div class="row g-3">
    <fieldset class="col-12">
      <%= f.label :port_from_id, class: "form-label" %>
      <%= render CardComponent.new() do |card| %>
        <div id="back_departure_server" class="back_server overflow-scroll">
          <%= render partial: "servers/draw_server_compact",
                      locals: { server: move.moveable, selected_port: move_connection.port_from } %>
        </div>
      <% end %>
      <%= f.hidden_field :port_from_id, value: move_connection.port_from_id %>
      <%= f.hidden_field :move_id, value: move.id %>
    </fieldset>
  </div>

  <fieldset class="col-12 mt-4">
    <%= f.label :port_to_id, class: "form-label" %>
    <%= render CardComponent.new() do |card| %>
      <% card.with_header do %>
        <div id="select_destination_bay">
          <span id="all_destinations">
            <%= select_tag "to_server",
                          options_for_select(
                            move.step.frame_servers_at_current_step_for(@move.frame).map { |v| [v.name, v.id] },
                            { selected: move_connection.port_to&.server }
                          ),
                          include_blank: true,
                          onchange: "select_destination_server(this.value)",
                          class: "form-select mx-auto",
                          style: "max-width: 185px;"
            %>
          </span>
        </div>
      <% end %>
      <div id="back_destination_server" class="back_server overflow-scroll">
        <% if move_connection.port_to %>
            <%= render partial: "servers/draw_server_compact",
                       locals: { server: move_connection.port_to.server, selected_port: move_connection.port_to } %>
        <% end %>
      </div>
    <% end %>
    <%= f.hidden_field :port_to_id, value: move_connection.port_to_id %>
  </fieldset>

  <fieldset class="col-12 mt-4">
    <%= f.label :vlans, class: "form-label" %>
    <%= f.text_field :vlans, class: "form-control", value: move_connection.vlans %>
  </fieldset>

  <fieldset class="col-12 mt-4">
    <%= f.label :cable_color, class: "form-label" %>
    <%= f.hidden_field :cable_color, value: move_connection.cable_color %>
  </fieldset>

  <fieldset class="col-12 mt-4">
    <%= f.label :cable_name, class: "form-label" %>
    <%= f.text_field :cable_name, class: "form-control", value: move_connection.cable_name %>
  </fieldset>

  <div class="col-12 mt-4 justify-content-between d-flex align-items-center">
    <%= f.submit t("action.save"), class: "btn btn-primary",
                                    disabled: move_connection.port_to_id.present? ? false : :disabled %>
    <span>
      <%= f.hidden_field :remove_connection, value: "0" %>
      <button type="button"
              class="btn btn-link link-danger link-underline link-underline-opacity-0 link-underline-opacity-100-hover"
              onclick="remove_connection()">
        <%= t(".action.delete") %>
      </button>
    </span>
  </div>
<% end %>

<script>
$(document).ready(function(){
    loadPaletteColorPicker('[name="move_connection[color]"]');
    $("#back_departure_server").on('click', 'a.port', function(e) {
        e.preventDefault();
    });
    $("#back_destination_server").on('click', 'a.port', function(e){
        e.preventDefault();
        select_destination_port(e.target.id);
    });
});

function select_destination_server(server_id){
    $("#back_destination_server").closest("form").find('input[type="submit"]').prop('disabled', true);
    if(server_id!=undefined && server_id!=''){
        $.ajax({
            method: "POST",
            url: "<%= connections_update_destination_server_path %>",
            data: { server_id: server_id, with_move_connection: 1 }
        }).done(function(){
            select_destination_port($('input[name="move_connection[port_to_id]"]').val());
        });
    }
}

function select_destination_port(port_id){
    if(port_id!=undefined && port_id!=''){
        var selected_port = $("#back_destination_server #"+port_id);
        console.log(port_id)
        console.log(selected_port)
        console.log(selected_port)
        selected_port.closest("table").find("span.selected").removeClass("selected");
        selected_port.closest("span").addClass("selected");
        var server_name = $("#back_destination_server .server_name").text();
        var component_name = selected_port.closest("td").find("span:first").data("composant-name");
        var position = selected_port.data("position");
        $('[name="move_connection[port_to_id]"]').val(port_id);
        selected_port.closest("form").find('input[type="submit"]').prop('disabled', false);
    }
}

function remove_connection(){
  $('form #move_connection_remove_connection')[0].value = '1';
  // TODO: calling submit crash the page, because it search for a view "update_connection"
  $('form.move_connection').trigger('submit.rails');
}
</script>
